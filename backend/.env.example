# Environment Configuration for Virtual Lab Backend
# Copy this to .env and update values as needed

# Server Configuration
PORT=8001
NODE_ENV=development

# Database Configuration
# Preferred for Supabase (Session pooler URI from Supabase dashboard):
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Or use individual DB_* values (local/self-managed Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=virtuallab_db
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here_change_this_in_production

# CORS Configuration
FRONTEND_URL=http://localhost:8080

# Logging Configuration
LOG_LEVEL=info